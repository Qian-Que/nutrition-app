PORT=4000
JWT_SECRET="please-change-this-secret"
CORS_ORIGIN="*"
SQLITE_PATH="./data/nutrition.db"

# ===== AI Provider 配置（支持非 GPT 模型） =====
# 可选值：
# - openai                  直接走 OpenAI Responses API（推荐 OpenAI 官方）
# - openai_compat_auto      先尝试 /responses，失败再尝试 /chat/completions（推荐第三方兼容平台）
# - openai_compat_responses 仅使用 /responses
# - openai_compat_chat      仅使用 /chat/completions
AI_PROVIDER="openai_compat_auto"

# OpenAI 官方： https://api.openai.com/v1
# 兼容平台示例： https://openrouter.ai/api/v1
# 兼容平台示例： https://api.siliconflow.cn/v1
# 兼容网关示例： https://your-oneapi-domain/v1
AI_BASE_URL="https://api.openai.com/v1"

# 优先读取 AI_API_KEY，若未设置会回退到 OPENAI_API_KEY
AI_API_KEY=""
# OPENAI_API_KEY=""

# 视觉模型（可填任意支持图像输入的模型 ID）
# 示例：
# - OpenAI: gpt-4.1-mini / gpt-4.1 / gpt-5.4-mini / gpt-5.4
# - 兼容平台: 按平台文档填写模型名（如 qwen-vl、gemini、llama-vision 等）
AI_MODEL="gpt-4.1-mini"

# 图片细节等级：low / high / auto
AI_IMAGE_DETAIL="auto"

# AI 请求超时（毫秒）
AI_TIMEOUT_MS="45000"

# ===== 兼容旧字段（可不填） =====
# OPENAI_VISION_MODEL="gpt-4.1-mini"
# OPENAI_IMAGE_DETAIL="auto"
